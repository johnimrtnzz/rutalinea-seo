# === Supabase ===
# Panel de Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxx

# === Anthropic (generación de artículos) ===
ANTHROPIC_API_KEY=sk-ant-xxxxx

# === Embeddings para enlazado interno (OpenAI o Voyage) ===
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-xxxxx

# === Investigación de keywords con volumen real (opcional al principio) ===
# Sin esto, la app sigue funcionando pero sin cifras de volumen/dificultad.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# === Seguimiento de posiciones (opcional al principio) ===
# Sin esto, el rank tracking no funcionará hasta que se contrate.
SERPAPI_KEY=

# === Stripe (se activa cuando esté todo listo) ===
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_STARTER=price_xxxxx
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_AGENCY=price_xxxxx

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
